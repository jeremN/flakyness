# Database
# Generate a secure password: openssl rand -hex 16
DATABASE_URL=postgres://postgres:<YOUR_DB_PASSWORD>@localhost:5432/flackyness
DB_PASSWORD=<YOUR_DB_PASSWORD>

# API
API_PORT=8080
API_HOST=0.0.0.0

# Dashboard
PUBLIC_API_URL=http://localhost:8080

# Security
# Generate a secure token: openssl rand -hex 32
ADMIN_TOKEN=change-me-in-production

# Dashboard HTTP Basic Auth — gates EVERY dashboard route (hooks.server.ts).
# If ADMIN_TOKEN is set (the mute/unmute action is live) and this is left
# unset, anyone who can reach the dashboard can mute a test unauthenticated —
# see docs/GETTING_STARTED.md's Production Deployment section. Leaving it
# unset is only safe for a genuinely network-isolated, single-operator setup.
# Generate a secure password: openssl rand -hex 32
# DASHBOARD_PASSWORD=

# Rate limiting — trusted reverse proxy IPs (comma-separated)
# Only requests from these IPs will have their X-Forwarded-For header trusted
# TRUSTED_PROXY_IPS=127.0.0.1,172.17.0.1

# Monitoring — set to enable GET /metrics (Prometheus scrape endpoint, unset = 404)
# Generate a secure token: openssl rand -hex 32
# METRICS_TOKEN=
