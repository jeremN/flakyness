{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "tsup src/index.ts --format esm",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file=../../.env node_modules/drizzle-kit/bin.cjs migrate",
    "db:push": "tsx --env-file=../../.env node_modules/drizzle-kit/bin.cjs push",
    "db:studio": "tsx --env-file=../../.env node_modules/drizzle-kit/bin.cjs studio",
    "db:seed": "tsx --env-file=../../.env src/db/seed.ts",
    "simulate:ci": "tsx --env-file=../../.env scripts/simulate-ci.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@hono/zod-validator": "^0.8.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.23",
    "hono-rate-limiter": "^0.5.3",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "drizzle-kit": "^0.31.10",
    "tsup": "^8.0.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
